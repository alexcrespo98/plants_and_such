    "id": "fn-toggle",
    "type": "function",
    "z": "tab-main",
    "name": "toggle play",
    "func": "var isPlaying = flow.get('sonosPlaying') || false;\nif (isPlaying) {\n    flow.set('sonosPlaying', false);\n    msg.url = 'http://192.168.0.32:8090/pause';\n} else {\n    flow.set('sonosPlaying', true);\n    msg.url = 'http://192.168.0.32:8090/play';\n}\nmsg.method = 'POST';\nmsg.payload = '';\nreturn msg;",
