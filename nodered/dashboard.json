  {
    "id": "fn-tick",
    "type": "function",
    "z": "tab-main",
    "name": "tick",
    "func": "var active = flow.get('timerActive');\n\n// Auto-stop check (runs even when inactive, to stop alarm after 10 min)\nvar timerStopAt = flow.get('timerStopAt') || 0;\nif (timerStopAt > 0 && Date.now() >= timerStopAt) {\n    flow.set('timerStopAt', 0);\n    flow.set('timerFired', false);\n    node.send([{payload:'-- : --'}, null,\n               {url:'http://192.168.0.32:8090/pause', method:'POST', payload:''}]);\n    return null;\n}\n\nif (!active) return null;\n\nvar endTime = flow.get('timerEnd') || 0;\nvar remaining = endTime - Date.now();\n\nif (remaining <= 0) {\n    var fired = flow.get('timerFired');\n    if (!fired) {\n        flow.set('timerFired', true);\n        flow.set('timerActive', false);\n        flow.set('timerStopAt', Date.now() + 10 * 60 * 1000);\n        node.send([\n            {payload: '00:00'},\n            {url:'http://192.168.0.32:8090/volume', method:'POST',\n             headers:{'Content-Type':'application/json'},\n             payload:JSON.stringify({volume:50})},\n            null\n        ]);\n    }\n    return null;\n}\n\nvar totalSecs = Math.ceil(remaining / 1000);\nvar mins = Math.floor(totalSecs / 60);\nvar secs = totalSecs % 60;\nmsg.payload = mins + ':' + secs.toString().padStart(2, '0');\nreturn [msg, null, null];",
    "outputs": 3,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 330,
    "y": 1580,
    "wires": [
      [
        "txt-countdown"
      ],
      [
        "http-timer-vol"
      ],
      [
        "http-timer-stop"
      ]
    ]
