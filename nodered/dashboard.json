  {
    "id": "fn-build-sched",
    "type": "function",
    "z": "tab-main",
    "name": "build schedule",
    "func": "if (msg.topic === 'onTime') {\n    flow.set('schedOn', msg.payload);\n} else if (msg.topic === 'offTime') {\n    flow.set('schedOff', msg.payload);\n}\nvar onTime = flow.get('schedOn') || '08:00';\nvar offTime = flow.get('schedOff') || '22:00';\nmsg.payload = JSON.stringify({on: onTime, off: offTime});\nmsg.topic = 'house/relay1/schedule/set';\nmsg.qos = 1;\nmsg.retain = true;\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 380,
    "y": 280,
    "wires": [
      [
        "mqtt-out-sched"
      ]
    ]
  },
