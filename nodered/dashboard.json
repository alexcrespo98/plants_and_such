  {
    "id": "fn-check-alarm",
    "type": "function",
    "z": "tab-main",
    "name": "check alarm",
    "func": "// Auto-stop check\nvar stopAt = flow.get('alarmStopAt') || 0;\nif (stopAt > 0 && Date.now() >= stopAt) {\n    flow.set('alarmStopAt', 0);\n    var stopMsg = {url:'http://192.168.0.32:8090/pause', method:'POST', payload:''};\n    return [null, stopMsg];\n}\n\nvar enabled = flow.get('alarmEnabled');\nif (!enabled) return null;\n\nvar days = flow.get('alarmDays') || {};\nvar times = flow.get('alarmTimes') || {mwf:'07:00',thf:'08:30',ss:'09:00'};\n\nvar now = new Date();\nvar dow = now.getDay();\nvar hh = now.getHours().toString().padStart(2,'0');\nvar mm = now.getMinutes().toString().padStart(2,'0');\nvar currentTime = hh + ':' + mm;\n\nvar dayKeys = ['sun','mon','tue','wed','thu','fri','sat'];\nvar todayKey = dayKeys[dow];\n\nif (!days[todayKey]) return null;\n\nvar targetTime;\nif (['mon','tue','wed'].indexOf(todayKey) >= 0) targetTime = times.mwf || '07:00';\nelse if (['thu','fri'].indexOf(todayKey) >= 0) targetTime = times.thf || '08:30';\nelse targetTime = times.ss || '09:00';\n\nif (currentTime !== targetTime) return null;\n\nvar firedKey = todayKey + '-' + now.getDate() + '-' + targetTime;\nvar firedAt = flow.get('alarmFiredAt') || '';\nif (firedAt === firedKey) return null;\n\nflow.set('alarmFiredAt', firedKey);\nflow.set('alarmStopAt', Date.now() + 10 * 60 * 1000);\n\nvar volMsg = {\n    url: 'http://192.168.0.32:8090/volume',\n    method: 'POST',\n    headers: {'Content-Type': 'application/json'},\n    payload: JSON.stringify({volume: 50})\n};\nreturn [volMsg, null];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 360,
    "y": 1260,
    "wires": [
      [
        "http-alarm-vol"
      ],
      [
        "http-alarm-stop"
      ]
    ]
  },
